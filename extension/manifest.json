{
  "manifest_version": 3,
  "name": "YouTube Activity Cleaner",
  "version": "1.0.0",
  "description": "Run the YouTube comment cleaner on the Google My Activity comments page.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["tabs", "power", "storage"],
  "host_permissions": ["https://myactivity.google.com/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "YouTube Activity Cleaner",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://myactivity.google.com/*"],
      "js": [
        "shared/browser-api.js",
        "shared/messages.js",
        "shared/constants.js",
        "shared/settings.js",
        "content/cleaner/config.js",
        "content/cleaner/selectors.js",
        "content/cleaner/state.js",
        "content/cleaner/scrolling.js",
        "content/cleaner/dom.js",
        "content/cleaner/status.js",
        "content/cleaner/engine.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
