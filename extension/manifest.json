{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extName__",
  "version": "4.0.0",
  "description": "__MSG_extDescription__",
  "homepage_url": "https://michalmatu.github.io/youtube-activity-cleaner/",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["tabs", "power", "storage"],
  "host_permissions": [
    "https://myactivity.google.com/*",
    "https://www.youtube.com/playlist*",
    "https://youtube.com/playlist*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://myactivity.google.com/*",
        "https://www.youtube.com/playlist*",
        "https://youtube.com/playlist*"
      ],
      "js": [
        "shared/browser-api.js",
        "shared/i18n.js",
        "shared/text.js",
        "shared/messages.js",
        "shared/targets.js",
        "shared/constants.js",
        "shared/settings.js",
        "content/cleaner/config.js",
        "content/cleaner/selectors.js",
        "content/cleaner/state.js",
        "content/cleaner/scrolling.js",
        "content/cleaner/dom.js",
        "content/cleaner/dom-viewport.js",
        "content/cleaner/dom-dialogs.js",
        "content/cleaner/dom-retry.js",
        "content/cleaner/status.js",
        "content/cleaner/candidates.js",
        "content/cleaner/strategies/my-activity-delete.js",
        "content/cleaner/strategies/playlist-remove.js",
        "content/cleaner/strategy.js",
        "content/cleaner/run-loop.js",
        "content/cleaner/lifecycle.js",
        "content/cleaner/engine.js",
        "content/debug.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
